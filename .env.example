# Django
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Docker Compose uses this automatically)
DATABASE_URL=postgres://mamiru:mamiru@db:5432/mamiru
POSTGRES_HOST_PORT=5433

# CSRF
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# SEO / public catalog URLs
PUBLIC_SITE_URL=https://www.example.com
PUBLIC_PRODUCT_PATH_PATTERN=/productos/{slug}/
PUBLIC_CATEGORY_PATH_PATTERN=/categorias/{slug}/

# Static & media files
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/data/media
SERVE_MEDIA_FILES=True
